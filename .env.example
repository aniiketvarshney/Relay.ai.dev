# ── Database (required for /api/registry and /api/publish) ───────────────────
# Easiest: Vercel → your Relay project → Storage → Connect Neon
# Vercel auto-injects these (any one pooled URL works; we map aliases automatically):
POSTGRES_URL=postgresql://user:pass@host/neondb?sslmode=require
DIRECT_URL=postgresql://user:pass@host/neondb?sslmode=require
# Aliases Vercel/Neon may use instead:
# POSTGRES_PRISMA_URL=...
# POSTGRES_URL_NON_POOLING=...
# DATABASE_URL=...

# After first deploy with env vars, push schema once (from your machine):
#   npx prisma db push

# ── AI providers (optional — for /demo) ──────────────────────────────────────
AI_GATEWAY_API_KEY=your_vercel_ai_gateway_key
AI_GATEWAY_MODEL=google/gemini-2.0-flash
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
