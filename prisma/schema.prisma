generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model AuditLog {
  id        String   @id @default(cuid())
  toolName  String
  action    String
  payload   Json
  riskScore Int
  blocked   Boolean
  reason    String?
  createdAt DateTime @default(now())
}
