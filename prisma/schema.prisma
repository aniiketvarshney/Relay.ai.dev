generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model AuditLog {
  id            String   @id @default(cuid())
  timestamp     DateTime @default(now())
  agentId       String
  toolName      String
  actionType    String
  payloadSummary String?
  riskScore     Int      @default(0)
  status        String
  userId        String?
  threatDetails String?
  metadata      Json?
  createdAt     DateTime @default(now())
}

model manifest {
  id          String      @id @default(cuid())
  name        String
  version     String
  description String?
  endpoint    String?
  domain      String?     // Added this field
  calledAt    DateTime    @default(now())

  telemetry   telemetry[]

}

model telemetry {
  id          String    @id @default(cuid())
  manifestId  String?
  toolName    String?
  eventType   String
  data        Json
  success     Boolean   @default(true)
  errorType   String?
  calledAt    DateTime  @default(now())

  manifest    manifest? @relation(fields: [manifestId], references: [id])
}

model McpConfig {
  id          String   @id @default(cuid())
  name        String
  config      Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}