generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model AuditLog {
  id        String   @id @default(cuid())
  toolName  String
  action    String
  payload   Json
  riskScore Int
  blocked   Boolean
  reason    String?
  createdAt DateTime @default(now())
}

model manifest {
  id          String   @id @default(cuid())
  name        String
  version     String
  description String?
  endpoint    String?
  calledAt    DateTime @default(now())
}

model telemetry {
  id        String   @id @default(cuid())
  eventType String
  data      Json
  calledAt  DateTime @default(now())
}